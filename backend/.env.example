APP_NAME=Enterprise AI Knowledge Base
DATABASE_URL=sqlite:///./data/app.db
SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
UPLOAD_DIR=./data/uploads
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
VISION_ENABLED=true
# Leave blank to reuse LLM_API_KEY, LLM_BASE_URL and LLM_MODEL.
VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL=
VISION_TIMEOUT_SECONDS=90
VISION_MAX_IMAGES_PER_DOCUMENT=20
OCR_MIN_PAGE_CHARACTERS=80
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSIONS=512
RETRIEVAL_TOP_K=8
RETRIEVAL_CANDIDATE_MULTIPLIER=4
RERANK_TOP_K=3
RETRIEVAL_MIN_SCORE=0.25
EVIDENCE_MIN_SCORE=0.38
EVIDENCE_MIN_LEXICAL_SCORE=0.08
CHUNK_SIZE=700
CHUNK_OVERLAP=100
CHAT_HISTORY_MESSAGES=8
RERANK_PROVIDER=llm
RERANK_API_KEY=
RERANK_BASE_URL=
RERANK_MODEL=BAAI/bge-reranker-v2-m3
TASK_POLL_INTERVAL_SECONDS=2
TASK_MAX_ATTEMPTS=3
TASK_RETRY_BASE_SECONDS=15
TASK_STALE_AFTER_SECONDS=900
RECYCLE_BIN_RETENTION_DAYS=30
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
UPLOAD_MAX_BYTES=26214400
UPLOAD_MAX_DOCUMENTS_PER_KB=100
AUTH_RATE_LIMIT=10
AUTH_RATE_WINDOW_SECONDS=60
UPLOAD_RATE_LIMIT=30
UPLOAD_RATE_WINDOW_SECONDS=60
CHAT_RATE_LIMIT=30
CHAT_RATE_WINDOW_SECONDS=60
# Prefer *_FILE in Docker deployments. Files must contain only the secret value.
# DATABASE_URL_FILE=/run/secrets/database_url
# SECRET_KEY_FILE=/run/secrets/secret_key
# LLM_API_KEY_FILE=/run/secrets/llm_api_key
# VISION_API_KEY_FILE=/run/secrets/vision_api_key
# RERANK_API_KEY_FILE=/run/secrets/rerank_api_key
